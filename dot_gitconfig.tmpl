[user]
	name = {{ .name }}
	email = {{ .email }}
[http]
	sslBackend = openssl
	postBuffer = 524288000
	lowSpeedLimit = 0
	lowSpeedTime = 999999
	sslVerify = false
	version = HTTP/1.1
[https]
	sslVersion = tlsv1.2
[filter "lfs"]
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
[safe]
	directory = *
[core]
	excludesFile = ~/.gitignore_global
